# MateObserve Configuration
# Copy to .env and customize

# ── Docker / Infrastructure ──────────────────────────────────────────────
POSTGRES_USER=mateobserve
POSTGRES_PASSWORD=changeme
POSTGRES_DB=mateobserve
REDIS_PASSWORD=changeme

# ── SDK (set in your API's environment) ──────────────────────────────────
MATEOBSERVE_SERVICE_NAME=my-api
MATEOBSERVE_COLLECTOR_URL=http://localhost:8001
MATEOBSERVE_API_KEY=

# ── Collector ────────────────────────────────────────────────────────────
MATEOBSERVE_DATABASE_URL=postgresql+asyncpg://mateobserve:changeme@localhost:5432/mateobserve
MATEOBSERVE_REDIS_URL=redis://:changeme@localhost:6379/0

# IMPORTANT: Change all 'changeme' passwords before deploying to production!

# ── Dashboard ────────────────────────────────────────────────────────────
NEXT_PUBLIC_COLLECTOR_URL=http://localhost:8001
NEXT_PUBLIC_API_KEY=
